# ─────────────────────────────────────────────────────────────
# LangGraph DeepAgents(JS) 챗 에이전트 — 환경변수 예시
# 복사: cp .env.example .env.local  (그리고 active provider 키 채우기)
# ★ 모든 키는 서버 전용. NEXT_PUBLIC_ 접두사 절대 금지 (R: 보안).
# ─────────────────────────────────────────────────────────────

# 프로바이더 스위칭 (R: FR-10)
LLM_PROVIDER=anthropic            # anthropic | openai (기본 anthropic)
LLM_MODEL=claude-sonnet-4-5-20250929   # provider 에 맞는 모델 ID (실측 후 확정)

# active provider 키만 있으면 됨 (env-precheck HARD PRECONDITION)
ANTHROPIC_API_KEY=                # LLM_PROVIDER=anthropic 일 때 필수
OPENAI_API_KEY=                   # LLM_PROVIDER=openai 일 때 필수

# 하네스 토글 — 실측 메커니즘은 docs/notes/deepagents-api-probe.md 참조
HARNESS_PLANNING=true             # false → excludedMiddleware:[TodoListMiddleware]
HARNESS_FILESYSTEM=true           # false → excludedTools:[ls,read_file,...] (soft toggle;
                                  #   FilesystemMiddleware 는 REQUIRED 라 제거 불가 — AD-6)
HARNESS_SUBAGENTS=false           # false → subagents:[] + GP subagent enabled:false
HARNESS_CHECKPOINTER=sqlite       # sqlite | memory
CHECKPOINTER_SQLITE_PATH=./.data/checkpoints.sqlite
